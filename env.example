# Copy this to .env for local testing (Railway: set these as service Variables instead)

DISCORD_BOT_TOKEN=your-discord-bot-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: restrict screenshot intake to one channel ID. Leave blank to watch all channels it can see.
BET_CHANNEL_ID=

# Optional: a separate channel where the cleaned-up bet summary + reactions get posted.
# Leave blank to just reply inline in the same channel as the screenshot.
OUTPUT_CHANNEL_ID=

# Optional: a channel where automatic daily/weekly/monthly recaps get posted.
# Leave blank to disable automatic recaps (you can still trigger them manually with /recap).
STATS_CHANNEL_ID=

# Optional: where to store the database. On Railway, set to /data/bets.db after attaching a volume at /data.
DB_PATH=bets.db

# Optional: if "true", anyone can react to settle a bet (not just the original poster)
ALLOW_ANYONE_TO_SETTLE=false
