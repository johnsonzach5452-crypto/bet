# Copy this to .env for local testing (Railway: set these as service Variables instead)

DISCORD_BOT_TOKEN=your-discord-bot-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GROUPS lets you run multiple totally separate bet-tracking setups (e.g. you and a
# friend, each with their own channels and their own stats/leaderboard that never mix).
# Must be valid JSON on a single line. Example with two groups:
# [{"name":"Jack","bet_channel_id":"123","output_channel_id":"456","stats_channel_id":"789"},{"name":"Friend","bet_channel_id":"111","output_channel_id":"222","stats_channel_id":"333"}]
#
# If you only need one group, you can skip GROUPS entirely and use these three instead:
GROUPS=
BET_CHANNEL_ID=
OUTPUT_CHANNEL_ID=
STATS_CHANNEL_ID=

# Optional: where to store the database. On Railway, set to /data/bets.db after attaching a volume at /data.
DB_PATH=bets.db

# Optional: if "true", anyone can react to settle a bet (not just the original poster)
ALLOW_ANYONE_TO_SETTLE=false
